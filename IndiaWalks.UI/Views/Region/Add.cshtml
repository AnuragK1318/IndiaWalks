@model IndiaWalks.UI.Models.Dto.AddRegionRequestDto

<div class="container mt-5">
    <div class="row justify-content-center">    
        <div class="col-lg-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-4">
                    <li class="breadcrumb-item"><a asp-controller="Region" asp-action="Index" class="text-decoration-none text-secondary">Regions</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Add New Region</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold">Create New Region</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">Fill in the details below to register a new region in the IndiaWalks system.</p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Code" class="form-label fw-semibold">Region Code</label>
                                <input type="text" class="form-control" asp-for="Code" placeholder="e.g. DEL" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="Name" class="form-label fw-semibold">Region Name</label>
                                <input type="text" class="form-control" asp-for="Name" placeholder="e.g. Delhi NCR" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Area" class="form-label fw-semibold">Area (km²)</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control" asp-for="Area" />
                                    <span class="input-group-text">km²</span>
                                </div>
                                <span asp-validation-for="Area" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Population" class="form-label fw-semibold">Population</label>
                                <input type="number" class="form-control" asp-for="Population" />
                                <span asp-validation-for="Population" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Lat" class="form-label fw-semibold">Latitude</label>
                                <input type="number" step="0.0001" class="form-control" asp-for="Lat" />
                                <span asp-validation-for="Lat" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Long" class="form-label fw-semibold">Longitude</label>
                                <input type="number" step="0.0001" class="form-control" asp-for="Long" />
                                <span asp-validation-for="Long" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="Regions" asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">Save Region</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>