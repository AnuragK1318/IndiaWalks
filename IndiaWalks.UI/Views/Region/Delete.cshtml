@model IndiaWalks.UI.Models.Dto.RegionDto

<div class="container mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item"><a asp-controller="Region" asp-action="Region" class="text-decoration-none text-muted">Regions</a></li>
                    <li class="breadcrumb-item active text-danger fw-bold">Delete Confirmation</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger p-4 text-center text-white">
                    <div class="display-4 mb-2">
                        <i class="bi bi-exclamation-octagon-fill animate-pulse"></i>
                    </div>
                    <h2 class="fw-bold mb-0">Confirm Deletion</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="text-muted fs-5">You are about to permanently remove:</p>
                        <h3 class="fw-bold text-dark border-bottom pb-3 d-inline-block">@Model.Name (@Model.Code)</h3>
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4 border-start border-4 border-danger">
                        <div class="row g-2 small text-secondary">
                            <div class="col-6"><strong>Population:</strong> @Model.Population.ToString("N0")</div>
                            <div class="col-6"><strong>Area:</strong> @Model.Area.ToString("N0") km²</div>
                            <div class="col-12 mt-1 text-truncate"><strong>Unique ID:</strong> @Model.Id</div>
                        </div>
                    </div>

                    <div class="alert alert-warning border-0 d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                        <div class="small">
                            <strong>Warning:</strong> Deleting this region will also affect any <strong>Walks</strong> or <strong>Guides</strong> associated with it. This cannot be undone.
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold py-3 shadow-sm hover-lift">
                                <i class="bi bi-trash3 me-2"></i> Yes, Delete Permanently
                            </button>
                            <a asp-action="Region" class="btn btn-link text-secondary text-decoration-none mt-2 fw-semibold">
                                Nevermind, take me back
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted x-small">Logged in as Administrator • @DateTime.Now.ToShortDateString()</p>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.8;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .hover-lift:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease;
        box-shadow: 0 0.5rem 1rem rgba(220, 53, 69, 0.25) !important;
    }

    .x-small {
        font-size: 0.75rem;
    }

    .rounded-4 {
        border-radius: 1.2rem;
    }
</style>