@model IndiaWalks.UI.Models.Dto.RegionDto

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-controller="Region" asp-action="Region" class="text-decoration-none">Regions</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Edit Region</h2>
                    <p class="text-muted mb-0">Modify details for <span class="text-primary fw-semibold">@Model.Name</span></p>
                </div>
                <a asp-controller="Region" asp-action="Region" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="bg-primary" style="height: 4px;"></div>

                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-controller="Region" asp-action="Edit">
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4"></div>

                        <div class="mb-5">
                            <h5 class="text-uppercase small fw-bold text-primary mb-3"><i class="bi bi-info-circle me-2"></i>General Information</h5>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <label asp-for="Code" class="form-label small fw-bold">Region Code</label>
                                    <input type="text" class="form-control form-control-lg bg-light border-0 fw-bold text-uppercase"
                                           asp-for="Code" maxlength="3" placeholder="e.g. MH" />
                                    <span asp-validation-for="Code" class="text-danger x-small"></span>
                                </div>
                                <div class="col-md-8">
                                    <label asp-for="Name" class="form-label small fw-bold">Region Name</label>
                                    <input type="text" class="form-control form-control-lg border-2 shadow-none" asp-for="Name" />
                                    <span asp-validation-for="Name" class="text-danger x-small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5 class="text-uppercase small fw-bold text-primary mb-3"><i class="bi bi-globe-central-south-asia me-2"></i>Geography & Metrics</h5>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label asp-for="Area" class="form-label small fw-bold text-secondary">Area Size</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-textarea-resize text-muted"></i></span>
                                        <input type="number" step="0.01" class="form-control border-start-0 ps-0 shadow-none" asp-for="Area" />
                                        <span class="input-group-text bg-light text-muted small fw-bold">km²</span>
                                    </div>
                                    <span asp-validation-for="Area" class="text-danger x-small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Population" class="form-label small fw-bold text-secondary">Current Population</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-people text-muted"></i></span>
                                        <input type="number" class="form-control border-start-0 ps-0 shadow-none" asp-for="Population" />
                                    </div>
                                    <span asp-validation-for="Population" class="text-danger x-small"></span>
                                </div>

                                <div class="col-md-12">
                                    <div class="p-3 bg-light rounded-3">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="Lat" class="form-label small text-muted mb-1">Latitude</label>
                                                <input type="number" step="0.0001" class="form-control form-control-sm border-0 shadow-sm" asp-for="Lat" />
                                                <span asp-validation-for="Lat" class="text-danger x-small"></span>
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Long" class="form-label small text-muted mb-1">Longitude</label>
                                                <input type="number" step="0.0001" class="form-control form-control-sm border-0 shadow-sm" asp-for="Long" />
                                                <span asp-validation-for="Long" class="text-danger x-small"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between pt-4 mt-4 border-top">
                            <button type="button" class="btn btn-link text-danger text-decoration-none fw-semibold p-0"
                                    onclick="location.href='@Url.Action("Delete", new { id = Model.Id })'">
                                <i class="bi bi-trash3 me-1"></i> Delete Region
                            </button>
                            <div class="d-flex gap-2">
                                <a asp-action="Region" class="btn btn-light px-4 fw-semibold">Cancel</a>
                                <button type="submit" class="btn btn-primary px-5 shadow fw-bold">
                                    Save Changes <i class="bi bi-check2-circle ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .x-small {
        font-size: 0.75rem;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .input-group-text {
        border: 2px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .form-control {
        border: 2px solid #dee2e6;
    }

    .form-control-sm {
        border: 1px solid transparent;
    }
</style>