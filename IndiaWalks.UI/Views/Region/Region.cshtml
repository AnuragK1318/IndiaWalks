@model IEnumerable<IndiaWalks.UI.Models.Dto.RegionDto>

<div class="container mt-4 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Regions</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Geographic Regions</h2>
            <p class="text-muted">Manage administrative boundaries and regional demographics.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-controller="Region" asp-action="Add" class="btn btn-primary shadow-sm px-4 py-2 rounded-pill">
                <i class="bi bi-plus-lg me-2"></i>Add New Region
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom">
            <div class="row align-items-center">
                <div class="col">
                    <h6 class="mb-0 fw-bold">Active Regions (@Model.Count())</h6>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-light border" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i> Print
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase small fw-bold">
                        <tr>
                            <th class="ps-4 py-3" style="width: 100px;">Code</th>
                            <th>Region Details</th>
                            <th>Geography</th>
                            <th>Demographics</th>
                            <th class="text-end pe-4">Manage</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var region in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold">
                                            @region.Code
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark fs-6">@region.Name</div>
                                        <div class="text-muted x-small">ID: @region.Id</div>
                                    </td>
                                    <td>
                                        <div class="small"><i class="bi bi-bounding-box me-1"></i> @region.Area.ToString("N0") km²</div>
                                        <div class="text-muted small">
                                            <i class="bi bi-geo"></i> @region.Lat.ToString("F2"), @region.Long.ToString("F2")
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small fw-semibold text-dark">
                                            <i class="bi bi-people-fill me-1 text-secondary"></i> @region.Population.ToString("N0")
                                        </div>
                                        <div class="progress mt-1" style="height: 4px; width: 80px;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width: 70%"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border dropdown-toggle shadow-none" type="button" data-bs-toggle="dropdown">
                                                Actions
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@region.Id"><i class="bi bi-pencil me-2 text-warning"></i> Edit Details</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@region.Id"><i class="bi bi-trash3 me-2"></i> Remove Region</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="mb-3 opacity-50" />
                                    <h5 class="text-muted">No regions found.</h5>
                                    <p class="small text-muted">Try adding a new region to get started.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3 border-top-0">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Viewing Page <strong>@ViewBag.PageNumber</strong></span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(ViewBag.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link shadow-none border-0" asp-action="Region" asp-route-pageNumber="@(ViewBag.PageNumber - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        <li class="page-item active"><span class="page-link rounded-circle mx-1">@ViewBag.PageNumber</span></li>
                        <li class="page-item">
                            <a class="page-link shadow-none border-0" asp-action="Region" asp-route-pageNumber="@(ViewBag.PageNumber + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8faff;
        transition: background-color 0.2s ease;
    }

    .x-small {
        font-size: 0.75rem;
    }

    .pagination .page-link {
        color: #444;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border: none;
    }
</style>